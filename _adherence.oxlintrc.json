{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chess/**",
              "components/core/**",
              "components/forms/**",
              "components/product/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rubik|Nunito|Lora|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Rubik, Nunito, Lora, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|iconLeft|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, size, iconLeft, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|teal|clay|olive|neutral|ink)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'teal' | 'clay' | 'olive' | 'neutral' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|full|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, full, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|accent|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'accent' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|title|tone|icon|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: children, title, tone, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:tip|rule|warning|fun)$/]",
        "message": "<Callout> tone must be one of 'tip' | 'rule' | 'warning' | 'fun'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|pad|interactive|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, pad, interactive, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:paper|cut|sunk)$/]",
        "message": "<Card> variant must be one of 'paper' | 'cut' | 'sunk'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|disabled|tone|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange, disabled, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|teal)$/]",
        "message": "<Checkbox> tone must be one of 'brand' | 'teal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoardPiece'] > JSXAttribute > JSXIdentifier[name!=/^(?:square|type|color|key|ref|className|style|children)$/]",
        "message": "<BoardPiece> doesn't accept that prop. Declared props: square, type, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoardPiece'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:white|black)$/]",
        "message": "<BoardPiece> color must be one of 'white' | 'black'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChessPiece'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|color|size|disc|tone|label|style|key|ref|className|style|children)$/]",
        "message": "<ChessPiece> doesn't accept that prop. Declared props: type, color, size, disc, tone, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChessPiece'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:white|black)$/]",
        "message": "<ChessPiece> color must be one of 'white' | 'black'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChessPiece'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|teal|paper)$/]",
        "message": "<ChessPiece> tone must be one of 'brand' | 'teal' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|label|variant|size|round|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, label, variant, size, round, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline|ghost)$/]",
        "message": "<IconButton> variant must be one of 'soft' | 'solid' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|leading|size|full|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, leading, size, full."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QRTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:seed|href|caption|size|play|style|key|ref|className|style|children)$/]",
        "message": "<QRTag> doesn't accept that prop. Declared props: seed, href, caption, size, play, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|checked|onChange|name|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: label, value, checked, onChange, name, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Step'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|key|ref|className|style|children)$/]",
        "message": "<Step> doesn't accept that prop. Declared props: title, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|shape|tone|size|tilt|peel|style|key|ref|className|style|children)$/]",
        "message": "<Sticker> doesn't accept that prop. Declared props: children, shape, tone, size, tilt, peel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle|seal)$/]",
        "message": "<Sticker> shape must be one of 'rounded' | 'circle' | 'seal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sticker'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:amber|teal|clay|paper)$/]",
        "message": "<Sticker> tone must be one of 'amber' | 'teal' | 'clay' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|defaultChecked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: label, checked, defaultChecked, onChange, disabled, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
